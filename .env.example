# Matchora Backend Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# MongoDB - Replace with your actual connection string
MONGODB_URI=mongodb+srv://Menmex:YOUR_PASSWORD@cluster0.j1kefxw.mongodb.net/matchora?retryWrites=true&w=majority

# JWT Secret - Generate a strong random string
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=7d

# CORS (frontend URL)
FRONTEND_URL=http://localhost:5500

# Cloudinary (for profile images - optional)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
